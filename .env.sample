# Copy this file to .env on the deployment host and fill in real secrets.

# Docker Compose
TZ=Asia/Seoul

# PostgreSQL container
POSTGRES_DB=aigo
POSTGRES_USER=aigo
POSTGRES_PASSWORD=replace-with-a-strong-db-password

# AiGo app
AIGO_API_KEY=replace-with-a-strong-api-key
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-JSS2D5YWFB

# Kakao Login
# Register this callback URL in Kakao Developers:
# https://your-domain.example/api/auth/kakao/callback
KAKAO_REST_API_KEY=replace-with-your-kakao-rest-api-key
# Optional, only if Kakao client secret is enabled for the app.
KAKAO_CLIENT_SECRET=

# Slack startup/shutdown notification webhook token (optional)
# Format: T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX
SLACK_TOKEN=
